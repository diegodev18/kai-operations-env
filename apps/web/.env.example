# URL pública del front (sin barra final). Debe coincidir con BETTER_AUTH_URL / WEB_ORIGIN de la API.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Destino interno de la API para rewrites del servidor Next.js (no exponer con NEXT_PUBLIC_):
# - /api/auth/*  → sesión Better Auth
# - /api/agents/* → listado Firestore (el navegador llama a rutas relativas /api/... con cookies)
NEXT_PUBLIC_API_URL=http://localhost:3001
