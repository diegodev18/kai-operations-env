{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/app.ts",
    "build": "bun -e \"console.log('[api] No bundle step; Bun runs TypeScript natively. Use bun run start.')\"",
    "start": "bun src/app.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:auth-schema": "bunx @better-auth/cli generate --config src/lib/auth.ts --output src/db/schema/auth.ts --yes",
    "seed": "bun scripts/seed.ts"
  },
  "dependencies": {
    "@google/genai": "^0.14.0",
    "@kai/shared": "*",
    "better-auth": "^1.5.5",
    "drizzle-orm": "^0.45.1",
    "firebase-admin": "^13.7.0",
    "hono": "^4.6.11",
    "pg": "^8.20.0",
    "sanitize-html": "^2.17.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.20.0",
    "@types/sanitize-html": "^2.16.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.0.0"
  }
}
