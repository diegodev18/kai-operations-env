# PostgreSQL (requerido)
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/kai_operations

# Better Auth — mínimo 32 caracteres en producción (ej. openssl rand -base64 32)
BETTER_AUTH_SECRET=change_me_use_a_long_random_secret_at_least_32_chars

# URL pública de la app Next (cookies / CSRF); suele ser http://localhost:3000 en dev
BETTER_AUTH_URL=http://localhost:3000

# Origen del front para CORS (misma URL que usa el navegador)
WEB_ORIGIN=http://localhost:3000

# Puerto de esta API (default 3001)
PORT=3001

# Usuario inicial (solo seed; registro público está desactivado)
SEED_USER_EMAIL=admin@example.com
SEED_USER_PASSWORD=change_me_strong_password
SEED_USER_NAME=Admin

# Firebase Admin / Firestore (opcional si usas archivo en src/tokens/firebase.production.json)
# En runtime Bun, Firestore usa transporte REST por defecto (evita errores @grpc/grpc-js). Forzar gRPC: FIRESTORE_PREFER_REST=0
# FIRESTORE_PREFER_REST=
# Nombre de la app Admin SDK (debe ser único si hay varias apps en el mismo proceso).
FIREBASE_APP_NAME=kai-operations-firestore
# JSON completo de la cuenta de servicio en una sola línea, o usa el archivo (no versionar).
# FIREBASE_SERVICE_ACCOUNT_JSON_PRODUCTION=
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Gemini / Prompt Designer
# Opción 1 (recomendada en local): API key de Gemini
# GEMINI_API_KEY=
#
# Opción 2 (Vertex AI): define proyecto + ubicación y credenciales Google
# VERTEX_AI_PROJECT=
# VERTEX_AI_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/ruta/absoluta/a/credentials.json
